# Zoho Mail credentials
ZOHO_EMAIL=you@yourdomain.com
ZOHO_PASSWORD=your_zoho_login_password
ZOHO_REGION=eu    # eu or com

# Only needed if 2FA is enabled on your Zoho account.
# If not set, ZOHO_PASSWORD is used for SMTP sending.
# ZOHO_APP_PASSWORD=your_app_specific_password

# API server auth key (change this before deploying)
API_KEY=changeme
